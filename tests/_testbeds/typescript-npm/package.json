{
  "private": true,
  "name": "@cyclonedx/cyclonedx-eslint-testbed-typescript-npm",
  "version": "1.0.0",
  "description": "TypeScript example using esbuild with npm",
  "type": "module",
  "main": "dist/bundle.js",
  "scripts": {
    "build": "node build.mjs",
    "start": "npm run build && node dist/bundle.js",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cyclonedx/cyclonedx-esbuild": "file:../../../",
    "@cyclonedx/cyclonedx-eslint-testing-reexport-package": "file:../../_data/reexport-package/package.tgz",
    "@cyclonedx/cyclonedx-eslint-testing-unused-package": "file:../../_data/unused-package/package.tgz",
    "@types/node": "ts5.9",
    "esbuild": "0.28.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@cyclonedx/cyclonedx-eslint-testing-custom-package": "file:../../_data/custom-package/package.tgz"
  },
  "packageManager": "npm",
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    }
  }
}
